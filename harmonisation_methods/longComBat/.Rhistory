library(longCombat)
library(invgamma)
library(lme4)
batch_col = "Scanner"   # column name
age = "Final_Age"
timepoint = "timepoint"
subject = "subjectID"
filename = "data_for_longComBat.csv"
userdata <- read.csv(filename, stringsAsFactors = FALSE, check.names = FALSE)
required_cols <- c(subject, timepoint, age, batch_col,
"T1_SIENAX_periphGM_norm_vol",
"T1_SIENAX_CSF_norm_vol",
"T1_SIENAX_GM_norm_vol",
"T1_SIENAX_WM_norm_vol",
"T1_SIENAX_brain_norm_vol",
"T1_FIRST_left_hippocampus",
"T1_FIRST_right_hippocampus")
required_cols <- intersect(required_cols, names(userdata))  # safe
userdata <- userdata[, required_cols, drop = FALSE]
simdata <- userdata
featurenames <- grep("^T1_", colnames(simdata), value=TRUE)
cat("Remaining dataset size:", nrow(simdata), "rows\n")
cat("Features available:", paste(featurenames, collapse=", "), "\n")
formula_str <- paste(age, timepoint, sep = " + ")
# term <- paste0("(1|", subject, ")") # This one is for scanner and site as fixed effects separately
term <- "(1|Site) + (1|subjectID)" # hardCoded
# for site as random effect and scanner as fixed effect
simdata[[subject]] <- as.factor(simdata[[subject]])   # Ensure grouping
# Only convert timepoint if it is categorical
if (is.character(simdata[[timepoint]]) || is.factor(simdata[[timepoint]])) {
simdata[[timepoint]] <- as.factor(simdata[[timepoint]])
}
simdata_combat <- longCombat(idvar = subject,
timevar = timepoint,
batchvar = batch_col,
features = featurenames,
formula = formula_str,
ranef = term,
data = simdata)
rm(list = ls())
