setwd("/Users/psyc1586_admin/GVB_data/harmonisation_work/00_aa_skullImprovement_Oct2025/run_harmonisation_pipelines/longComBat")
library(longCombat)
library(invgamma)
library(lme4)
batch_col = "Scanner" # treat scanner as batch
Scanner = "Scanner"   # column name
Site="Site"
age = "Final_Age"
timepoint = "timepoint"
subject = "subjectID"
filename = "data_for_longComBat.csv"
userdata <- read.csv(filename, stringsAsFactors = FALSE, check.names = FALSE)
required_cols <- c(subject, timepoint, age, Scanner, Site,
"T1_SIENAX_periphGM_norm_vol",
"T1_SIENAX_CSF_norm_vol",
"T1_SIENAX_GM_norm_vol",
"T1_SIENAX_WM_norm_vol",
"T1_SIENAX_brain_norm_vol",
"T1_FIRST_left_hippocampus",
"T1_FIRST_right_hippocampus")
required_cols <- intersect(required_cols, names(userdata))  # safe
userdata <- userdata[, required_cols, drop = FALSE]
simdata <- userdata
featurenames <- grep("^T1_", colnames(simdata), value=TRUE)
simdata[[Site]] <- as.factor(simdata[[Site]])
simdata[[Scanner]] <- as.factor(simdata[[Scanner]])
simdata[[subject]] <- as.factor(simdata[[subject]])
simdata[[timepoint]] <- as.factor(simdata[[timepoint]])
formula_str <- paste(age, timepoint, sep = " + ")
if (batch_col %in% c("Scanner", "Site")) {
term <- paste0("(1|", subject, ")")
outname <- batch_col
} else if (batch_col == "Scanner_Site") {
batch_col <- "Scanner"
outname <- "ScannerF_SiteR"
term <- paste0("(1|", subject, ") ", "+ (1|",  Site, ")")
} else {
term <- NULL
}
simdata_combat <- longCombat(idvar = subject,
timevar = timepoint,
batchvar = batch_col,
features = featurenames,
formula = formula_str,
ranef = term,
data = simdata)
simdata_harmonized <- simdata_combat$data_combat
output_file_path <- paste0(tools::file_path_sans_ext(filename), "_harmonised_", outname, ".csv")
write.csv(simdata_harmonized, output_file_path, row.names = FALSE)
rm(list = ls())
